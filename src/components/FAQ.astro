---
import { getLang, t } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).faq;
---
<section id="faq" class="px-6 py-24 md:py-32" style="background: var(--color-zeed-panel)">
  <div class="mx-auto max-w-3xl">
    <p
      class="mb-3 text-center text-xs uppercase tracking-[0.2em]"
      style="color: var(--color-zeed-glow)"
    >
      {s.eyebrow}
    </p>
    <h2 class="mb-12 text-center text-3xl md:text-5xl">
      {s.heading}
    </h2>

    <div class="space-y-3">
      {s.items.map((f, i) => (
        <details
          class="rounded-xl border p-5 transition group"
          style="border-color: var(--color-zeed-border); background: var(--color-zeed-bg)"
          open={i === 0}
        >
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
            <h3 class="text-base font-medium leading-relaxed" style="color: var(--color-zeed-text)">{f.q}</h3>
            <span class="mt-0.5 text-xs transition group-open:rotate-180" style="color: var(--color-zeed-glow)">▾</span>
          </summary>
          <p class="mt-4 text-sm leading-relaxed" style="color: var(--color-zeed-muted)">
            {f.a}
          </p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- JSON-LD FAQPage schema for AIO / SEO (LLM pulled answers, Google rich snippets) -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    inLanguage: lang === "ja" ? "ja" : "en",
    mainEntity: s.items.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: f.a,
      },
    })),
  })}
/>
