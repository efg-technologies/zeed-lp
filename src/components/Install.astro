---
import { getLang, t } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).install;
---
<section id="install" class="px-6 py-24 md:py-32" style="background: var(--color-zeed-panel)">
  <div class="mx-auto max-w-3xl">
    <h2 class="mb-4 text-center text-4xl md:text-5xl">{s.heading}</h2>
    <p class="mb-12 text-center" style="color: var(--color-zeed-muted)">
      {s.subhead}
    </p>

    <div
      class="rounded-2xl border p-8 mb-6"
      style="border-color: var(--color-zeed-border); background: var(--color-zeed-bg)"
    >
      <h3 class="mb-3 text-lg font-semibold">{s.archTitle}</h3>
      <p class="mb-2 text-sm" style="color: var(--color-zeed-muted)">{s.archHelperLabel}</p>
      <pre class="mb-4"><code>yay -S zeed-bin</code></pre>

      <p class="mb-2 text-sm" style="color: var(--color-zeed-muted)">{s.archManualLabel}</p>
      <pre><code>git clone https://aur.archlinux.org/zeed-bin.git
cd zeed-bin
makepkg -si</code></pre>
    </div>

    <div
      class="rounded-2xl border p-8 mb-6"
      style="border-color: var(--color-zeed-border); background: var(--color-zeed-bg)"
    >
      <h3 class="mb-3 text-lg font-semibold">{s.debTitle}</h3>
      <p class="mb-2 text-sm" style="color: var(--color-zeed-muted)">{s.debLabel}</p>
      <pre class="mb-2"><code>curl -LO https://github.com/efg-technologies/zeed-browser-dist/releases/latest/download/zeed-browser_147.0.7727.55.49-1_amd64.deb
sudo apt install ./zeed-browser_147.0.7727.55.49-1_amd64.deb</code></pre>
      <p class="text-xs" style="color: var(--color-zeed-muted)">
        {s.debAptNote}
      </p>
    </div>

    <div
      class="rounded-2xl border p-8"
      style="border-color: var(--color-zeed-border); background: var(--color-zeed-bg)"
    >
      <div class="mb-3 flex items-center gap-3">
        <h3 class="text-lg font-semibold">{s.macTitle}</h3>
        <span
          class="rounded-full px-2 py-0.5 text-xs font-medium"
          style="background: rgba(167,139,250,0.15); color: #a78bfa; border: 1px solid rgba(167,139,250,0.3)"
        >{s.macBetaBadge}</span>
      </div>
      <p class="mb-3 text-sm" style="color: var(--color-zeed-muted)">{s.macDescription}</p>

      <p class="mb-2 text-sm" style="color: var(--color-zeed-muted)">{s.macBrewLabel}</p>
      <pre class="mb-4"><code>brew install --cask efg-technologies/zeed/zeed</code></pre>

      <p class="mb-2 text-sm" style="color: var(--color-zeed-muted)">{s.macManualLabel}</p>
      <pre class="mb-2"><code>curl -LO https://github.com/efg-technologies/zeed-browser-dist/releases/latest/download/zeed-147.0.7727.55.49-mac-arm64.dmg
xattr -dr com.apple.quarantine /Applications/Zeed\ Browser.app</code></pre>
      <p class="text-xs" style="color: var(--color-zeed-muted)">
        {s.macQuarantineNote}
      </p>
    </div>

    <p class="mt-8 text-center text-sm" style="color: var(--color-zeed-muted)">
      {s.firstRun}<br />
      <a href="mailto:support@efg-technologies.com?subject=Zeed%20feedback">{s.issuesLink}</a>
    </p>
  </div>
</section>
