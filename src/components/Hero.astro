---
import HeroVisual from "./HeroVisual.astro";
import { getLang, t } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).hero;
const installHref = lang === "ja" ? "/ja/#install" : "/#install";
const compareHref = lang === "ja" ? "/ja/#compare" : "/#compare";
---
<section class="relative overflow-hidden px-6 pt-16 pb-20 md:pt-28 md:pb-28">
  <div
    class="pointer-events-none absolute -top-40 left-1/2 h-[700px] w-[700px] -translate-x-1/2 rounded-full opacity-50 blur-3xl"
    style="background: radial-gradient(circle, var(--color-zeed-accent) 0%, transparent 65%)"
  ></div>
  <div
    class="pointer-events-none absolute top-60 right-0 h-[400px] w-[400px] rounded-full opacity-20 blur-3xl"
    style="background: radial-gradient(circle, var(--color-zeed-glow) 0%, transparent 70%)"
  ></div>

  <div class="relative mx-auto max-w-5xl">
    <div class="mb-8 flex justify-center">
      <a
        href="https://github.com/efg-technologies/zeed-browser/releases/latest"
        class="inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-xs font-mono transition hover:border-transparent"
        style="border-color: var(--color-zeed-border); background: var(--color-zeed-panel)"
      >
        <span class="h-2 w-2 animate-pulse rounded-full" style="background: #4ade80"></span>
        <span style="color: var(--color-zeed-muted)">{s.badge}</span>
        <span style="color: var(--color-zeed-glow)">→</span>
      </a>
    </div>

    <h1 class="mb-8 text-center text-4xl leading-[1.1] md:text-6xl md:leading-[1.05]">
      <span class="block" set:html={s.title1}></span>
      <span
        class="block bg-clip-text text-transparent"
        style="background-image: linear-gradient(120deg, var(--color-zeed-glow), var(--color-zeed-accent-2))"
      >
        {s.title2}
      </span>
    </h1>

    <p
      class="mx-auto mb-10 max-w-2xl text-center text-lg md:text-xl"
      style="color: var(--color-zeed-muted)"
    >
      {lang === "ja" ? (
        <>
          タブ・記憶・閲覧中の文脈を使って<strong style="color: var(--color-zeed-text)">{s.leadBoldA}</strong>。
          必要なら<strong style="color: var(--color-zeed-text)">{s.leadBoldB}</strong>。
          <br class="hidden md:inline" />
          <strong style="color: var(--color-zeed-text)">{s.leadBoldC}</strong>
          {s.leadTail}
        </>
      ) : (
        <>
          Zeed <strong style="color: var(--color-zeed-text)">{s.leadBoldA}</strong>, and
          <strong style="color: var(--color-zeed-text)"> {s.leadBoldB}</strong>.
          <br class="hidden md:inline" />
          <strong style="color: var(--color-zeed-text)">{s.leadBoldC}</strong> {s.leadTail}
        </>
      )}
    </p>

    <HeroVisual />

    <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={installHref}
        class="rounded-xl px-8 py-4 text-base font-semibold text-white transition hover:opacity-90"
        style="background: var(--color-zeed-accent-2)"
      >
        {s.ctaInstall}
      </a>
      <a
        href={compareHref}
        class="rounded-xl border px-8 py-4 text-base font-semibold transition hover:border-transparent"
        style="border-color: var(--color-zeed-border); color: var(--color-zeed-text)"
      >
        {s.ctaCompare}
      </a>
    </div>

    <p class="mt-6 text-center text-sm" style="color: var(--color-zeed-muted)">
      {s.tagline}
    </p>
    <p class="mt-2 text-center text-xs" style="color: var(--color-zeed-muted)">
      {s.chromeNote}
    </p>

    <div
      class="mt-16 grid grid-cols-2 gap-3 rounded-2xl border p-6 md:grid-cols-4 md:gap-6"
      style="border-color: var(--color-zeed-border); background: rgba(20, 20, 26, 0.6)"
    >
      <div class="text-center">
        <div class="text-2xl font-bold md:text-3xl" style="color: var(--color-zeed-glow)">0</div>
        <div class="mt-1 text-xs" style="color: var(--color-zeed-muted)">{s.stat1Label}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold md:text-3xl" style="color: var(--color-zeed-glow)">2</div>
        <div class="mt-1 text-xs" style="color: var(--color-zeed-muted)">{s.stat2Label}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold md:text-3xl" style="color: var(--color-zeed-glow)">{lang === "ja" ? "5層" : "5"}</div>
        <div class="mt-1 text-xs" style="color: var(--color-zeed-muted)">{s.stat3Label}</div>
      </div>
      <div class="text-center">
        <div class="text-2xl font-bold md:text-3xl" style="color: var(--color-zeed-glow)">300+</div>
        <div class="mt-1 text-xs" style="color: var(--color-zeed-muted)">{s.stat4Label}</div>
      </div>
    </div>
  </div>
</section>
