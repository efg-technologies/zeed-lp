---
import { getLang, t } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).hero;
---
<div class="relative mx-auto mb-12 max-w-4xl">
  <div
    class="pointer-events-none absolute inset-0 rounded-[28px] opacity-30 blur-2xl"
    style="background: radial-gradient(ellipse at 70% 50%, var(--color-zeed-accent) 0%, transparent 60%)"
  ></div>

  <svg
    viewBox="0 0 800 500"
    xmlns="http://www.w3.org/2000/svg"
    role="img"
    aria-label="Zeed browser window illustration — vertical tab sidebar on the left, webpage in the middle, Zeed AI sidebar on the right"
    class="relative w-full drop-shadow-2xl"
  >
    <defs>
      <linearGradient id="glow" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#8B5CF6" stop-opacity="0.6" />
        <stop offset="100%" stop-color="#5B21B6" stop-opacity="0.1" />
      </linearGradient>
      <linearGradient id="chip-grad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#8B5CF6" stop-opacity="0.35" />
        <stop offset="100%" stop-color="#5B21B6" stop-opacity="0.15" />
      </linearGradient>
      <filter id="soft-glow">
        <feGaussianBlur stdDeviation="3" />
      </filter>
    </defs>

    <!-- Window shadow -->
    <rect x="28" y="32" width="760" height="460" rx="14" fill="#000" opacity="0.4" filter="url(#soft-glow)" />

    <!-- Window body -->
    <rect x="20" y="20" width="760" height="460" rx="14" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />

    <!-- Title bar (slim) -->
    <rect x="20" y="20" width="760" height="32" rx="14" fill="#1A1A1F" />
    <rect x="20" y="46" width="760" height="6" fill="#1A1A1F" />
    <line x1="20" y1="52" x2="780" y2="52" stroke="#2A2A34" stroke-width="1" />

    <!-- Traffic lights -->
    <circle cx="38" cy="36" r="6" fill="#ff5f57" />
    <circle cx="58" cy="36" r="6" fill="#febc2e" />
    <circle cx="78" cy="36" r="6" fill="#28c840" />

    <!-- URL area in title bar, minimal -->
    <rect x="300" y="28" width="220" height="16" rx="8" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
    <circle cx="312" cy="36" r="2.5" fill="#9B9BA3" />
    <rect x="320" y="33" width="120" height="6" rx="2" fill="#6B6B73" />

    <!-- Body: vertical tabs (left) | main (middle) | Zeed sidebar (right) -->
    <g transform="translate(20,52)">
      <!-- VERTICAL TAB STRIP (left, 56 wide) -->
      <rect x="0" y="0" width="56" height="428" fill="#1A1A1F" />
      <line x1="56" y1="0" x2="56" y2="428" stroke="#2A2A34" stroke-width="1" />

      <!-- small title row at top of tab strip -->
      <rect x="12" y="14" width="18" height="3" rx="1.5" fill="#9B9BA3" opacity="0.6" />
      <rect x="12" y="20" width="12" height="3" rx="1.5" fill="#6B6B73" />

      <!-- Tab items (vertical, rounded pills). Active = purple accent -->
      <g transform="translate(8,40)">
        <!-- Active tab -->
        <rect x="0" y="0" width="40" height="40" rx="8" fill="url(#chip-grad)" stroke="#8B5CF6" stroke-width="1" />
        <circle cx="12" cy="20" r="4" fill="#8B5CF6" />
        <rect x="20" y="14" width="14" height="3" rx="1.5" fill="#E7E7EA" opacity="0.9" />
        <rect x="20" y="20" width="10" height="3" rx="1.5" fill="#9B9BA3" opacity="0.7" />
        <rect x="20" y="26" width="12" height="3" rx="1.5" fill="#9B9BA3" opacity="0.7" />
      </g>

      <g transform="translate(8,88)">
        <rect x="0" y="0" width="40" height="40" rx="8" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
        <rect x="10" y="16" width="6" height="6" rx="1" fill="#6B6B73" />
        <rect x="20" y="14" width="14" height="3" rx="1.5" fill="#9B9BA3" opacity="0.5" />
        <rect x="20" y="20" width="10" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
        <rect x="20" y="26" width="12" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
      </g>

      <g transform="translate(8,136)">
        <rect x="0" y="0" width="40" height="40" rx="8" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
        <rect x="10" y="16" width="6" height="6" rx="1" fill="#6B6B73" />
        <rect x="20" y="14" width="14" height="3" rx="1.5" fill="#9B9BA3" opacity="0.5" />
        <rect x="20" y="20" width="10" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
        <rect x="20" y="26" width="12" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
      </g>

      <!-- TabGroup separator label -->
      <text x="14" y="200" fill="#6B6B73" font-size="8" font-family="-apple-system,sans-serif">Work</text>
      <line x1="12" y1="204" x2="44" y2="204" stroke="#2A2A34" stroke-width="1" />

      <g transform="translate(8,214)">
        <rect x="0" y="0" width="40" height="40" rx="8" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
        <rect x="10" y="16" width="6" height="6" rx="1" fill="#6B6B73" />
        <rect x="20" y="14" width="14" height="3" rx="1.5" fill="#9B9BA3" opacity="0.5" />
        <rect x="20" y="20" width="10" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
        <rect x="20" y="26" width="12" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
      </g>

      <g transform="translate(8,262)">
        <rect x="0" y="0" width="40" height="40" rx="8" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
        <rect x="10" y="16" width="6" height="6" rx="1" fill="#6B6B73" />
        <rect x="20" y="14" width="14" height="3" rx="1.5" fill="#9B9BA3" opacity="0.5" />
        <rect x="20" y="20" width="10" height="3" rx="1.5" fill="#6B6B73" opacity="0.5" />
      </g>

      <!-- + button at bottom -->
      <g transform="translate(18,390)">
        <circle cx="10" cy="10" r="10" fill="#2A2A34" />
        <text x="10" y="14" fill="#9B9BA3" font-size="14" text-anchor="middle" font-family="-apple-system,sans-serif">+</text>
      </g>

      <!-- MAIN CONTENT (middle) -->
      <g transform="translate(56,0)">
        <rect x="0" y="0" width="444" height="428" fill="#0F0F12" />

        <!-- page heading -->
        <g transform="translate(40,40)">
          <rect x="0" y="0" width="240" height="14" rx="3" fill="#E7E7EA" opacity="0.9" />
          <rect x="0" y="28" width="180" height="10" rx="3" fill="#9B9BA3" opacity="0.6" />
        </g>

        <!-- paragraph lines -->
        <g transform="translate(40,100)" fill="#3A3A45">
          <rect x="0" y="0" width="360" height="6" rx="2" />
          <rect x="0" y="14" width="340" height="6" rx="2" />
          <rect x="0" y="28" width="320" height="6" rx="2" />
          <rect x="0" y="42" width="300" height="6" rx="2" />
          <rect x="0" y="56" width="180" height="6" rx="2" />
        </g>

        <!-- highlight: AI picked an important sentence -->
        <rect x="40" y="112" width="340" height="8" rx="2" fill="#8B5CF6" opacity="0.35" />

        <!-- image / card -->
        <rect x="40" y="190" width="360" height="100" rx="6" fill="#1A1A1F" stroke="#2A2A34" stroke-width="1" />
        <g transform="translate(40,190)" opacity="0.25">
          <rect x="20" y="20" width="50" height="50" rx="4" fill="#8B5CF6" />
          <rect x="80" y="30" width="80" height="8" rx="2" fill="#E7E7EA" />
          <rect x="80" y="48" width="130" height="5" rx="2" fill="#9B9BA3" />
          <rect x="80" y="60" width="100" height="5" rx="2" fill="#9B9BA3" />
        </g>

        <!-- more lines -->
        <g transform="translate(40,310)" fill="#3A3A45">
          <rect x="0" y="0" width="340" height="6" rx="2" />
          <rect x="0" y="14" width="360" height="6" rx="2" />
          <rect x="0" y="28" width="260" height="6" rx="2" />
        </g>
      </g>

      <!-- ZEED SIDEBAR (right) -->
      <g transform="translate(500,0)">
        <rect x="0" y="0" width="260" height="428" fill="#1A1A1F" />
        <line x1="0" y1="0" x2="0" y2="428" stroke="#2A2A34" stroke-width="1" />

        <!-- accent glow top: AI active pulse -->
        <rect x="0" y="0" width="260" height="2" fill="url(#glow)">
          <animate attributeName="opacity" values="0.5;1;0.5" dur="3s" repeatCount="indefinite" />
        </rect>

        <!-- Zeed header -->
        <g transform="translate(20,24)">
          <circle cx="8" cy="8" r="4" fill="#8B5CF6">
            <animate attributeName="opacity" values="1;0.5;1" dur="2s" repeatCount="indefinite" />
          </circle>
          <text x="22" y="13" fill="#E7E7EA" font-size="13" font-weight="700" font-family="-apple-system,sans-serif">Zeed</text>
          <rect x="180" y="4" width="40" height="10" rx="2" fill="#2A2A34" />
          <text x="184" y="12" fill="#9B9BA3" font-size="8" font-family="-apple-system,sans-serif">Context</text>
        </g>

        <!-- Context Map: small force-directed graph -->
        <g transform="translate(130,110)">
          <line x1="0" y1="0" x2="-40" y2="-25" stroke="#5B21B6" stroke-width="1" opacity="0.5" />
          <line x1="0" y1="0" x2="40" y2="-28" stroke="#5B21B6" stroke-width="1" opacity="0.5" />
          <line x1="0" y1="0" x2="-30" y2="30" stroke="#5B21B6" stroke-width="1" opacity="0.5" />
          <line x1="0" y1="0" x2="35" y2="32" stroke="#5B21B6" stroke-width="1" opacity="0.5" />
          <line x1="-40" y1="-25" x2="40" y2="-28" stroke="#5B21B6" stroke-width="0.5" opacity="0.25" />
          <line x1="-30" y1="30" x2="35" y2="32" stroke="#5B21B6" stroke-width="0.5" opacity="0.25" />

          <circle cx="0" cy="0" r="10" fill="#8B5CF6">
            <animate attributeName="r" values="10;12;10" dur="2.5s" repeatCount="indefinite" />
          </circle>
          <circle cx="-40" cy="-25" r="6" fill="#1A1A1F" stroke="#8B5CF6" stroke-width="1.5" />
          <circle cx="40" cy="-28" r="6" fill="#1A1A1F" stroke="#8B5CF6" stroke-width="1.5" />
          <circle cx="-30" cy="30" r="5" fill="#1A1A1F" stroke="#A78BFA" stroke-width="1.5" />
          <circle cx="35" cy="32" r="5" fill="#1A1A1F" stroke="#A78BFA" stroke-width="1.5" />
        </g>

        <line x1="20" y1="195" x2="240" y2="195" stroke="#2A2A34" stroke-width="1" />

        <!-- Chat bubbles -->
        <g transform="translate(20,215)">
          <rect x="90" y="0" width="150" height="28" rx="7" fill="#5B21B6" />
          <rect x="98" y="10" width="100" height="4" rx="2" fill="#E7E7EA" opacity="0.9" />
          <rect x="98" y="20" width="80" height="4" rx="2" fill="#E7E7EA" opacity="0.6" />

          <g transform="translate(0,40)">
            <rect x="0" y="0" width="120" height="18" rx="9" fill="#2A2A34" stroke="#5B21B6" stroke-width="1" stroke-dasharray="2,2" />
            <text x="10" y="12" fill="#A78BFA" font-size="9" font-family="ui-monospace,monospace">◈ read_page</text>
          </g>
          <g transform="translate(0,64)">
            <rect x="0" y="0" width="100" height="18" rx="9" fill="#2A2A34" stroke="#5B21B6" stroke-width="1" stroke-dasharray="2,2" />
            <text x="10" y="12" fill="#A78BFA" font-size="9" font-family="ui-monospace,monospace">◈ search</text>
          </g>

          <g transform="translate(0,95)">
            <rect x="0" y="0" width="210" height="48" rx="7" fill="#1A1A1F" stroke="#2A2A34" stroke-width="1" />
            <rect x="10" y="10" width="180" height="4" rx="2" fill="#E7E7EA" opacity="0.8" />
            <rect x="10" y="20" width="160" height="4" rx="2" fill="#9B9BA3" opacity="0.7" />
            <rect x="10" y="30" width="140" height="4" rx="2" fill="#9B9BA3" opacity="0.7" />
          </g>
        </g>

        <!-- input -->
        <g transform="translate(20,380)">
          <rect x="0" y="0" width="220" height="28" rx="6" fill="#0F0F12" stroke="#2A2A34" stroke-width="1" />
          <text x="10" y="18" fill="#6B6B73" font-size="10" font-family="-apple-system,sans-serif">{s.inputPlaceholder}</text>
        </g>
      </g>

      <!-- Data flow arc: page content → Zeed sidebar -->
      <g opacity="0.7">
        <path
          d="M 380 230 Q 470 220 560 260"
          stroke="#8B5CF6"
          stroke-width="1.5"
          fill="none"
          stroke-dasharray="4,4"
          opacity="0.5"
        >
          <animate attributeName="stroke-dashoffset" values="0;-16" dur="1.5s" repeatCount="indefinite" />
        </path>
      </g>
    </g>
  </svg>

  <p class="mt-4 text-center text-xs" style="color: var(--color-zeed-muted)">
    {s.visualCaption}
  </p>
</div>
