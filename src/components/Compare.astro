---
import { getLang, t } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).compare;
---
<section id="compare" class="px-6 py-24 md:py-32" style="background: var(--color-zeed-panel)">
  <div class="mx-auto max-w-5xl">
    <p
      class="mb-3 text-center text-xs uppercase tracking-[0.2em]"
      style="color: var(--color-zeed-glow)"
    >
      {s.eyebrow}
    </p>
    <h2 class="mb-4 text-center text-4xl md:text-5xl">
      {s.heading}
    </h2>
    <p
      class="mb-12 text-center text-sm md:text-base"
      style="color: var(--color-zeed-muted)"
    >
      {s.subhead}
    </p>

    <div class="overflow-x-auto">
      <table
        class="w-full border-collapse overflow-hidden rounded-2xl text-sm"
        style="background: var(--color-zeed-bg)"
      >
        <thead>
          <tr
            class="border-b"
            style="border-color: var(--color-zeed-border); background: var(--color-zeed-panel-2)"
          >
            <th class="px-4 py-4 text-left font-medium" style="color: var(--color-zeed-muted)">
              {s.colFeature}
            </th>
            <th
              class="px-4 py-4 text-center font-bold"
              style="color: var(--color-zeed-glow)"
            >
              Zeed
            </th>
            <th class="px-4 py-4 text-center" style="color: var(--color-zeed-muted)">Atlas</th>
            <th class="px-4 py-4 text-center" style="color: var(--color-zeed-muted)">Comet</th>
            <th class="px-4 py-4 text-center" style="color: var(--color-zeed-muted)">Fellou</th>
            <th class="px-4 py-4 text-center" style="color: var(--color-zeed-muted)">Opera Neon</th>
          </tr>
        </thead>
        <tbody>
          {s.rows.map((row) => (
            <tr class="border-b" style="border-color: var(--color-zeed-border)">
              <td class="px-4 py-3">{row.label}</td>
              <td
                class="px-4 py-3 text-center font-mono font-bold"
                style="color: var(--color-zeed-glow)"
              >
                {row.zeed}
              </td>
              <td class="px-4 py-3 text-center font-mono" style="color: var(--color-zeed-muted)">
                {row.atlas}
              </td>
              <td class="px-4 py-3 text-center font-mono" style="color: var(--color-zeed-muted)">
                {row.comet}
              </td>
              <td class="px-4 py-3 text-center font-mono" style="color: var(--color-zeed-muted)">
                {row.fellou}
              </td>
              <td class="px-4 py-3 text-center font-mono" style="color: var(--color-zeed-muted)">
                {row.opera}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p
      class="mt-8 text-center text-xs"
      style="color: var(--color-zeed-muted)"
    >
      {s.legend}
      <br />
      <span class="mt-2 inline-block">{s.sourceNote}</span>
    </p>
  </div>
</section>
