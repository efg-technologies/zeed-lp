---
import { getLang, t, altLangUrl } from "../lib/i18n";
const lang = getLang(Astro.currentLocale);
const s = t(lang).footer;
const privacyHref = lang === "ja" ? "/ja/privacy" : "/privacy";
const termsHref = lang === "ja" ? "/ja/terms" : "/terms";
const altLang = lang === "ja" ? "en" : "ja";
const altHref = altLangUrl(Astro.url.pathname, altLang);
---
<footer class="border-t px-6 py-12" style="border-color: var(--color-zeed-border)">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-6 md:flex-row md:justify-between">
    <div class="text-sm" style="color: var(--color-zeed-muted)">
      {s.copyright}
    </div>
    <nav class="flex flex-wrap justify-center gap-6 text-sm">
      <a href={privacyHref}>{s.privacy}</a>
      <a href={termsHref}>{s.terms}</a>
      <a href="https://github.com/efg-technologies/zeed-browser">{s.github}</a>
      <a href="https://github.com/efg-technologies/zeed-browser/issues">{s.issues}</a>
      <a href={altHref} hreflang={altLang} rel="alternate">{s.altLang}</a>
    </nav>
  </div>
</footer>
