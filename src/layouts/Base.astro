---
import "../styles/global.css";
import { getLang, altLangUrl } from "../lib/i18n";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}
const { title, description, canonicalPath } = Astro.props;

const lang = getLang(Astro.currentLocale);
const pathname = Astro.url.pathname;
const canonicalURL = new URL(canonicalPath ?? pathname, Astro.site);

// hreflang alternates
const enHref = new URL(altLangUrl(pathname, "en"), Astro.site).toString();
const jaHref = new URL(altLangUrl(pathname, "ja"), Astro.site).toString();

// Organization + SoftwareApplication structured data.
// AIO / SEO: LLM が直接引用しやすい、Google rich snippets に出やすい。
const softwareAppJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Zeed Browser",
  alternateName: "Zeed",
  applicationCategory: "BrowserApplication",
  operatingSystem: "Linux (Arch, Ubuntu, Debian); macOS coming soon",
  url: "https://zeed.run",
  description:
    lang === "ja"
      ? "あなたのタブ・記憶・閲覧文脈を中心に考える Chromium ベースの AI ブラウザ。個人データは端末から出ない設計。OpenRouter 経由で 300+ LLM (GPT / Claude / Gemini など) から好きなモデルを選べる。Chrome の拡張機能・ブックマーク・パスワードをそのまま引き継げる。"
      : "A Chromium-based AI browser that reasons over your tabs, memory, and reading context. Personal data never leaves your device by design. Pick from 300+ LLMs (GPT / Claude / Gemini…) via OpenRouter. Your Chrome extensions, bookmarks, and saved passwords carry over.",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: lang === "ja" ? "JPY" : "USD",
  },
  creator: {
    "@type": "Organization",
    name: "EFG Technologies Inc.",
    url: "https://efg-technologies.com",
  },
  softwareVersion: "147.0.7727.55.49",
  downloadUrl:
    "https://github.com/efg-technologies/zeed-browser-dist/releases/latest",
  license: "https://www.mozilla.org/en-US/MPL/2.0/",
  inLanguage: lang === "ja" ? "ja" : "en",
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="ja" href={jaHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={lang === "ja" ? "ja_JP" : "en_US"} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(softwareAppJsonLd)}
    />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
